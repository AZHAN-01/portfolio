# Database Credentials
MYSQLHOST=your_mysql_host
MYSQLUSER=your_mysql_user
MYSQLPASSWORD=your_mysql_password
MYSQLPORT=3306
MYSQLDATABASE=your_mysql_database

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Configuration
ADMIN_PASSWORD=admin123
ADMIN_SESSION_TOKEN=azhan-super-secret-session-token

# SMTP Credentials (Optional - for Admin password resets)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# Resend API Configuration (Recommended alternative for Render Free Tier)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=onboarding@resend.dev

# JWT Secret (Required - generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=your_jwt_secret_here
